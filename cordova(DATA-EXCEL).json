      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of items) {\n  const barangay = item.json.barangay;\n\n  for (const resident of item.json.residents) {\n    output.push({\n      json: {\n        barangay: barangay,\n        firstname: resident.firstname,\n        middlename: resident.middlename,\n        lastname: resident.lastname\n      }\n    });\n  }\n}\n\nreturn output;\n"
