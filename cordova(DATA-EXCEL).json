    {
      "parameters": {
        "jsCode": "// Get your input data\nconst data = $input.first().json.data;\n\n// Group residents by barangay\nconst grouped = {};\n\ndata.forEach(r => {\n  const barangay = r.barangay.barangay_name;\n\n  if (!grouped[barangay]) {\n    grouped[barangay] = [];\n  }\n\n  grouped[barangay].push({\n    firstname: r.prof_firstname,\n    middlename: r.prof_middlename || \"\",\n    lastname: r.prof_lastname\n  });\n});\n\n// Return ONE item per barangay\nreturn Object.keys(grouped).map(barangay => ({\n  json: {\n    barangay: barangay,        // Spreadsheet name\n    residents: grouped[barangay]\n  }\n}));\n"
      },
